# Padrão para todos os arquivos texto
* text=auto

# Scripts Linux
*.sh text eol=lf
mvnw text eol=lf

# Scripts Windows
*.cmd text eol=crlf
*.bat text eol=crlf

# Código fonte (sempre LF)
*.java text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf